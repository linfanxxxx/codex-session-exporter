{
  "name": "codex-session-exporter",
  "version": "0.1.0",
  "description": "Export, import, and share local Codex sessions as bundles, Markdown, and HTML.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "codex-session-exporter": "./bin/codex-session-exporter.mjs",
    "codex-session-portability": "./bin/codex-session-portability.mjs"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "skills",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "keywords": [
    "codex",
    "codex-cli",
    "session",
    "export",
    "import",
    "markdown",
    "html",
    "sqlite",
    "cli-tool",
    "session-export"
  ],
  "author": "zhouyifan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linfanxxxx/codex-session-exporter.git"
  },
  "homepage": "https://github.com/linfanxxxx/codex-session-exporter#readme",
  "bugs": {
    "url": "https://github.com/linfanxxxx/codex-session-exporter/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "list": "node ./bin/codex-session-exporter.mjs list",
    "inspect": "node ./bin/codex-session-exporter.mjs inspect",
    "export:md": "node ./bin/codex-session-exporter.mjs export md",
    "export:html": "node ./bin/codex-session-exporter.mjs export html",
    "export:bundle": "node ./bin/codex-session-exporter.mjs export bundle",
    "import:bundle": "node ./bin/codex-session-exporter.mjs import bundle",
    "install:cli": "./scripts/install-cli.sh",
    "install:github": "./scripts/install-from-github.sh",
    "install:skill": "./scripts/install-skill.sh",
    "install:skill:cli": "node ./bin/codex-session-exporter.mjs install skill"
  }
}
